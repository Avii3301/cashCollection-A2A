# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Databricks / MLflow ───────────────────────────────────────────────────────
# Leave MLFLOW_TRACKING_URI=databricks to use Databricks as the MLflow backend.
# To run without Databricks, set MLFLOW_TRACKING_URI=http://127.0.0.1:5000
# and run: mlflow server --port 5000
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=dapi...
MLFLOW_TRACKING_URI=databricks
MLFLOW_EXPERIMENT_NAME=/Shared/cash-collection-drafter

# ── Service ───────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:8000

# ── Evaluation ────────────────────────────────────────────────────────────────
# Set to true to enable the LLM-as-judge scorer (uses additional OpenAI credits)
LLM_JUDGE_ENABLED=false
